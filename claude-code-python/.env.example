# CCP Configuration File
# Copy this file to .env and fill in your values

# ============================================
# API Provider Selection
# ============================================

# Use Aliyun (通义千问) - Set to 1 to enable
USE_ALIYUN=1

# ============================================
# Aliyun DashScope API (通义千问)
# ============================================
# Get API key from: https://dashscope.console.aliyun.com/

DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# Alternative variable name (also works)
# ALIYUN_API_KEY=sk-xxxxxxxxxxxxxxxx

# ============================================
# Anthropic API (Claude)
# ============================================
# Get API key from: https://console.anthropic.com/

# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ============================================
# Optional Settings
# ============================================

# Default model (for Aliyun)
# Options: qwen-turbo, qwen-plus, qwen-max, qwen-max-longcontext
# ALIYUN_MODEL=qwen-plus

# Default model (for Anthropic)
# Options: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-20250514
# DEFAULT_MODEL=claude-sonnet-4-20250514

# Verbose logging
# VERBOSE=1
