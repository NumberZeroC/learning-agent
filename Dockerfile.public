# Learning Agent 公开知识展示网站 - 生产环境镜像
# 分支：public-release
# 功能：只读知识展示（隐藏工作流、聊天、配置）

# 基于已有的 learning-agent 镜像构建
FROM learning-agent:latest

# 设置工作目录
WORKDIR /app

# 设置环境变量
ENV PUBLIC_MODE=true \
    HIDE_WORKFLOW_EXECUTION=true \
    HIDE_CONFIG_PAGE=true \
    PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# 复制应用代码
COPY . .

# 创建日志和数据目录
RUN mkdir -p logs data/workflow_results data/llm_audit_logs

# 暴露端口
EXPOSE 80

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:80/health')" || exit 1

# 启动命令
CMD ["python", "web/app.py", "--host", "0.0.0.0", "--port", "80"]
