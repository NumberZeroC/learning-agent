# Learning Agent 环境变量配置
# 复制此文件为 .env 并填入实际值

# ============================================
# 必需配置
# ============================================

# 阿里云 DashScope API Key
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-api-key-here

# ============================================
# 可选配置（生产环境建议配置）
# ============================================

# Web API 认证 Token（用于保护 API 接口）
# 生成方法：openssl rand -hex 32
# LEARNING_AGENT_TOKEN=

# 工作流启动密钥（对外公开时保护知识生成功能）
# 生成方法：openssl rand -hex 16
# WEB_ADMIN_KEY=

# Flask 运行配置
# FLASK_ENV=production
# FLASK_DEBUG=0

# 工作流配置
# WORKFLOW_MAX_RETRIES=3
# WORKFLOW_TIMEOUT=180

# 日志配置
# LOG_LEVEL=INFO
